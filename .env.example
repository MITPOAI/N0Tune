# N0Tune Phase 0 local development configuration.
# Values here are safe placeholders. Do not put real secrets in this file.

N0TUNE_ENVIRONMENT=development
N0TUNE_API_HOST=0.0.0.0
N0TUNE_API_PORT=8000
N0TUNE_DATABASE_URL=postgresql+psycopg://n0tune:n0tune_dev_password_change_me@postgres:5432/n0tune
N0TUNE_REDIS_URL=redis://redis:6379/0
N0TUNE_CORS_ORIGINS=["http://localhost:3000"]

POSTGRES_DB=n0tune
POSTGRES_USER=n0tune
POSTGRES_PASSWORD=n0tune_dev_password_change_me

REDIS_URL=redis://redis:6379/0
NEXT_PUBLIC_N0TUNE_API_BASE_URL=http://localhost:8000

# Future phases will use hashed app API keys. This is a local placeholder only.
N0TUNE_APP_API_KEY=replace-with-local-development-key

# Future provider gateway placeholders. Leave blank until Phase 2/3.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LITELLM_BASE_URL=

# Rate limiting. 0 disables. Use the redis backend for multi-replica deployments.
N0TUNE_RATE_LIMIT_RPM=0
N0TUNE_RATE_LIMIT_WINDOW_SECONDS=60
N0TUNE_RATE_LIMIT_BACKEND=memory

# Embedding provider. "hash" (default) is deterministic and dependency-free.
# Set to "openai" to call an OpenAI-compatible /embeddings endpoint, or
# "fastembed" to run a local sentence-transformers model (requires the
# optional `fastembed` package).
N0TUNE_EMBEDDING_PROVIDER=hash
N0TUNE_EMBEDDING_MODEL=text-embedding-3-small
N0TUNE_EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
N0TUNE_EMBEDDING_OPENAI_API_KEY=
N0TUNE_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# Hybrid retrieval. 0.0 = pure vector. 1.0 = pure BM25 lexical. Values in
# between blend normalized vector + lexical scores per candidate.
N0TUNE_HYBRID_LEXICAL_WEIGHT=0.0

# Optional Langfuse observability. Leave the keys blank to disable. Requires
# the optional `langfuse` package to be installed (pip install langfuse).
N0TUNE_LANGFUSE_PUBLIC_KEY=
N0TUNE_LANGFUSE_SECRET_KEY=
N0TUNE_LANGFUSE_HOST=https://cloud.langfuse.com
