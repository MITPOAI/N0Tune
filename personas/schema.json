{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n0tune.dev/schemas/persona.json",
  "title": "N0Tune Persona (.n0tune file)",
  "type": "object",
  "required": ["format", "version", "persona"],
  "properties": {
    "format": { "const": "n0tune-persona" },
    "version": { "type": "integer", "minimum": 1 },
    "persona": {
      "type": "object",
      "required": ["name", "style", "memoryMode"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "avatar": {
          "type": "string",
          "description": "Path or URL to an avatar image. Defaults to the N0Tune logo."
        },
        "personality": { "type": "string", "maxLength": 2000 },
        "style": {
          "type": "object",
          "required": ["tone", "depth", "format", "avoid"],
          "properties": {
            "tone": { "type": "string", "maxLength": 64 },
            "depth": { "type": "string", "maxLength": 64 },
            "format": { "type": "string", "maxLength": 128 },
            "avoid": {
              "type": "array",
              "items": { "type": "string", "maxLength": 128 },
              "maxItems": 16
            }
          }
        },
        "memoryMode": {
          "enum": ["auto", "review", "manual", "off"]
        },
        "allowedTools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional list of MCP tool names this persona is allowed to expose."
        }
      }
    },
    "memories": {
      "type": "array",
      "description": "OPTIONAL exported memories. By default this is omitted from shared personas.",
      "items": {
        "type": "object",
        "required": ["type", "text"],
        "properties": {
          "type": { "type": "string" },
          "text": { "type": "string", "maxLength": 4000 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
