{
  "name": "n0tune",
  "version": "0.1.2",
  "private": true,
  "description": "N0Tune monorepo: context compiler and AI memory gateway.",
  "workspaces": [
    "apps/dashboard",
    "apps/desktop",
    "integrations/mcp-server",
    "integrations/vercel-ai-sdk",
    "packages/cli",
    "packages/sdk-js"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format:check": "prettier --check \"**/*.{md,json,ts,tsx,js,mjs,css,yml,yaml}\"",
    "mcp:sync": "node scripts/sync-mcp-config.mjs",
    "postinstall": "node -e \"try{require('node:fs').accessSync('scripts/sync-mcp-config.mjs');require('node:child_process').execFileSync(process.execPath,['scripts/sync-mcp-config.mjs'],{stdio:'inherit'})}catch(e){if(e.code!=='ENOENT')throw e}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "overrides": {
    "next@15.5.18": {
      "postcss": "8.5.14"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
